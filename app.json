{
  "expo": {
    "name": "PRITECH Tasks",
    "slug": "pritech-tasks",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pritech.tasks"
    },
    "android": {
      "package": "com.pritech.tasks"
    },
    "web": {
      "bundler": "metro"
    },
    "scheme": "pritechtasks",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f7f8fb",
          "imageWidth": 200
        }
      ]
    ]
  }
}